{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Iris",
  "version": "0.1.0",
  "identifier": "com.nousresearch.hermes-agent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Iris",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 720,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#07080b",
        "trafficLightPosition": {
          "x": 18,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src ipc: http://ipc.localhost http://127.0.0.1:* https://*; frame-src 'self' data: blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
