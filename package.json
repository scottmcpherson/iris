{
  "name": "iris-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "npm install && npm run core:setup",
    "core:setup": "node scripts/setup-iris-core.mjs",
    "core:dev": "iris-core/.venv/bin/iris-core --host 127.0.0.1 --port 8765",
    "core:test": "node scripts/test-iris-core.mjs",
    "core:build:binary": "node iris-core/scripts/build-binary.mjs",
    "core:build:binary:universal": "node iris-core/scripts/build-binary.mjs --target-arch universal2",
    "iris:platform:install": "node scripts/install-iris-platform.mjs",
    "iris:hermes:install": "node scripts/install-iris-platform.mjs",
    "iris:reset": "node scripts/reset-iris-environment.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:web": "node scripts/dev.mjs --web",
    "dev:desktop": "node scripts/dev.mjs",
    "dev:mobile-pairing": "node scripts/dev.mjs --mobile",
    "dev:no-core": "node scripts/dev.mjs --no-core",
    "mobile:dev": "npm --workspace apps/mobile run start",
    "mobile:ios": "npm --workspace apps/mobile run ios --",
    "mobile:ios:simulator": "npm --workspace apps/mobile run ios:simulator --",
    "mobile:android": "npm --workspace apps/mobile run android",
    "mobile:test": "npm --workspace apps/mobile run test",
    "mobile:typecheck": "npm --workspace apps/mobile run typecheck",
    "check": "npm --workspace apps/desktop run check && npm run core:test",
    "build": "npm --workspace apps/desktop run build",
    "build:mac:app": "npm run core:build:binary && npm --workspace apps/desktop run build:mac:app",
    "build:mac:app:universal": "npm run core:build:binary:universal && npm --workspace apps/desktop run build:mac:app:universal",
    "package:check": "npm --workspace apps/desktop run package:check"
  },
  "engines": {
    "node": ">=22",
    "python": ">=3.11"
  }
}
