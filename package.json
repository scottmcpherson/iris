{
  "name": "iris-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "desktop"
  ],
  "scripts": {
    "bootstrap": "npm install && npm run sidecar:setup",
    "sidecar:setup": "node scripts/setup-sidecar.mjs",
    "sidecar:dev": "sidecar/.venv/bin/iris-core --host 127.0.0.1 --port 8765",
    "sidecar:test": "sidecar/.venv/bin/python -m pytest sidecar",
    "hermes:agentui:install": "node scripts/install-agentui-platform.mjs",
    "iris:hermes:install": "node scripts/install-agentui-platform.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:web": "node scripts/dev.mjs --web",
    "dev:desktop": "node scripts/dev.mjs",
    "dev:no-sidecar": "node scripts/dev.mjs --no-sidecar",
    "check": "npm --workspace desktop run check && npm run sidecar:test",
    "build": "npm --workspace desktop run build",
    "build:mac:app": "npm --workspace desktop run build:mac:app",
    "package:check": "npm --workspace desktop run package:check"
  },
  "engines": {
    "node": ">=22",
    "python": ">=3.11"
  }
}
