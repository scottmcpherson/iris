{
  "name": "@iris/theme",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./native": {
      "types": "./generated/native-theme.ts",
      "default": "./generated/native-theme.ts"
    },
    "./desktop.css": "./generated/desktop-tokens.css"
  },
  "scripts": {
    "generate": "node scripts/generate-theme.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "typescript": "~5.8.3",
    "vitest": "^4.1.5"
  }
}
