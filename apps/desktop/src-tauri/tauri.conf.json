{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Iris",
  "version": "0.1.1",
  "identifier": "com.nousresearch.hermes-agent.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Iris",
        "width": 1440,
        "height": 920,
        "minWidth": 480,
        "minHeight": 720,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#07080b",
        "trafficLightPosition": {
          "x": 18,
          "y": 22
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob: http://127.0.0.1:* http://localhost:* http://* https://*; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* http://* https://*; frame-src 'self';",
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$TEMP/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/iris-core"
    ],
    "resources": [
      "python/core_bridge.py"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["iris"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMxQTFFRjA4NjE4MkRGOUIKUldTYjM0SmhDTytod1dkTFdCRXFKcnJGeUZIcmZrMUZBUlV6TnJuNngrSzloTG5sL2ZhQXhvSEsK",
      "endpoints": [
        "https://github.com/scottmcpherson/iris/releases/latest/download/latest.json"
      ]
    }
  }
}
