{
  "expo": {
    "name": "Iris Mobile",
    "slug": "iris-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "iris-mobile",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.nousresearch.iris.mobile",
      "icon": "./assets/expo.icon",
      "appleTeamId": "5E845CEVPW",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Iris Mobile connects to Iris Core on your desktop during device pairing and local development.",
        "NSPhotoLibraryUsageDescription": "Allow Iris Mobile to access your photos.",
        "NSCameraUsageDescription": "Allow Iris Mobile to use your camera to take photos.",
        "NSMicrophoneUsageDescription": "Allow Iris Mobile to access your microphone.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "ts.net": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "android": {
      "package": "com.nousresearch.iris.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#07080b",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#07080b",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Iris Mobile to access your microphone."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Iris Mobile to access your photos.",
          "cameraPermission": "Allow Iris Mobile to use your camera to take photos."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
